@model IEnumerable<Delivery_Modelos.Pedido>
@{
    ViewData["Title"] = "Pedidos Registrados";
}

<div class="page-header">
    <h2 class="page-title">Pedidos Registrados</h2>
    <a href="/" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver
    </a>
</div>

<div class="glass-card">
    @if (Model == null || !Model.Any())
    {
        <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.5;">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            </svg>
            <p>No se encontraron pedidos registrados en el sistema.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ID Pedido</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Repartidor Asignado</th>
                        <th>Estado</th>
                        <th>Total Pago</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model)
                    {
                        <tr>
                            <td style="font-weight: 600;">#@pedido.IdPedido</td>
                            <td>@pedido.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (pedido.Usuario?.Persona != null)
                                {
                                    <span>@pedido.Usuario.Persona.Nombre @pedido.Usuario.Persona.Apellido</span>
                                }
                                else
                                {
                                    <span style="color: var(--text-muted);">Usuario #@pedido.Usuario?.IdUsuario</span>
                                }
                            </td>
                            <td>
                                @if (pedido.Delivery?.Persona != null)
                                {
                                    <span>@pedido.Delivery.Persona.Nombre @pedido.Delivery.Persona.Apellido (@pedido.Delivery.Vehiculo)</span>
                                }
                                else
                                {
                                    <span style="color: var(--warning); font-style: italic;">Pendiente de Asignación</span>
                                }
                            </td>
                            <td>
                                @{
                                    var estado = pedido.Estado?.ToLower() ?? "pendiente";
                                    if (estado == "entregado" || estado == "completado")
                                    {
                                        <span class="badge badge-success">@pedido.Estado</span>
                                    }
                                    else if (estado == "cancelado" || estado == "rechazado")
                                    {
                                        <span class="badge badge-danger">@pedido.Estado</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">@pedido.Estado</span>
                                    }
                                }
                            </td>
                            <td style="font-weight: 600; color: #10B981;">
                                @if (pedido.Pago != null)
                                {
                                    <span>$@pedido.Pago.Monto.ToString("N2") <small style="font-size: 0.75rem; color: var(--text-muted);">(@pedido.Pago.MetodoPago)</small></span>
                                }
                                else
                                {
                                    <span style="color: var(--text-muted);">Sin Pago</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
