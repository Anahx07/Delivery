@{
    ViewData["Title"] = "Panel de Control";
}

<div class="hero-content">
    <span class="hero-badge">Gestor de Operaciones</span>
    <h1>Gestión de Delivery Inteligente</h1>
    <p class="hero-subtitle">
        Administra de forma centralizada tus repartidores, pedidos en tiempo real, catálogo de productos y clientes desde un panel de control con diseño intuitivo y moderno.
    </p>
    <div class="cta-group">
        <a href="/Pedidos" class="btn btn-primary">Ver Pedidos Activos</a>
        <a href="/Productos" class="btn btn-secondary">Gestionar Catálogo</a>
    </div>
</div>

<div class="feature-grid">
    <a href="/Clientes" class="feature-card">
        <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
        </div>
        <h3>Clientes</h3>
        <p>Visualiza y administra la lista completa de personas registradas, sus datos de contacto y direcciones principales de entrega.</p>
    </a>

    <a href="/Pedidos" class="feature-card">
        <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
        </div>
        <h3>Pedidos</h3>
        <p>Monitorea las órdenes de compra, revisa el estado actual de los despachos, el repartidor asignado y los pagos realizados.</p>
    </a>

    <a href="/Productos" class="feature-card">
        <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                <line x1="12" y1="22.08" x2="12" y2="12"></line>
            </svg>
        </div>
        <h3>Productos</h3>
        <p>Controla el inventario de artículos disponibles, actualiza los precios unitarios y revisa los niveles de stock crítico.</p>
    </a>
</div>
